{
  "manifest_version": 3,
  "name": "LeetRemind",
  "version": "1.0",
  "description": "Daily LeetCode reminder with streak tracking and goal setting",
  "permissions": [
    "notifications",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeetRemind"
  }
}
